# ── GCP / Cloud Run deployment target ──────────────────────────────────────────
# These control where deploy.sh builds and deploys the service.
# Copy this file to .env and fill in values for your own environment.

GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"

# Cloud Run service name
CR_SERVICE_NAME="MY_CR_SERVICE_NAME"

# Artifact Registry repository name (will be created if it doesn't exist)
ARTIFACT_REPO="cloud-run-source-deploy"

# ── Application ─────────────────────────────────────────────────────────────────

# Public URL of the deployed service (used as APP_URL in the Cloud Run env)
# Defaults to: https://<CR_SERVICE_NAME>-<GCP_PROJECT_NUMBER>.<GCP_REGION>.run.app
APP_URL=""

# AI Studio applet ID injected into the nginx-container env.
# Create your own at https://aistudio.google.com and set your applet ID here.
APPLET_ID="your-ai-studio-applet-id"

# ── Datadog ──────────────────────────────────────────────────────────────────────

# Datadog environment tag (default: prod)
DD_ENV="prod"

# ── API keys (local development only) ───────────────────────────────────────────
# In Cloud Run, these are injected at runtime from GCP Secret Manager.
# You only need them here when running the app locally (npm run dev).

GEMINI_API_KEY="MY_GEMINI_API_KEY"
DD_API_KEY="MY_DD_API_KEY"
DD_APP_KEY="MY_DD_APP_KEY"
DD_SITE="datadoghq.com"

# ── Datadog RUM ──────────────────────────────────────────────────────────────────
# These are browser-safe (write-only) tokens; safe to expose in the client bundle.
# Find them in Datadog → UX Monitoring → RUM Applications → your app → Setup.
DD_RUM_APP_ID="your-rum-application-id"
DD_RUM_CLIENT_TOKEN="your-rum-client-token"
